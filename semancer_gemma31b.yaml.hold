# EXL3 QLoRA — Gemma-4-31B-it (4bpw) on semancy. Session-28 validated recipe:
# rsLoRA + PiSSA, alpha = r, lr 1e-5 (cooled after the 5e-5 divergence), 4 epochs.
# Launch: PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
#           python training/qlora_train.py --config semancer_gemma31b.yaml

# Required
model: /home/unstable/weights/googlegemma-4-31B-it/4
out: out/semancer_gemma31b

# Execution mode — 29 GB of weights needs both 3090s; head on cuda:1
parallel: split
use_per_device: [13, 17]    # both GPUs need ~5.5GB headroom for the fp32 embed/head upcast (preapply_had_l OOM, 2026-07-12)

# LoRA / optimization
r: 32
alpha: 32                   # alpha = r; with rsLoRA eff scale = 32/sqrt(32) ~= 5.7
use_rslora: true
init_lora: pissa
lr: 0.00001                 # 1e-5 — 5e-5 diverged on gemma+PiSSA (12B run, 2026-07-12)
weight_decay: 0.01
scheduler: cosine
warmup_ratio: 0.1           # ~7 real warmup steps at ~70 packed steps; 1-step warmup fed the divergence
epochs: 4                   # ~70 packed steps total; save_best still picks the sweet spot
batch: 4
grad_accum: 1
max_grad_norm: 1.0
compute_dtype: bfloat16

# Data
dataset: UnstableLlama/semancy
messages_key: messages      # semancy is an OpenAI-style chat dataset
prompt_format: gemma4-nothink
seq_len: 2048               # packed blocks of 2048 (~5 examples/block at ~400 tok)
pack: true
pack_algo: bfd              # best-fit decreasing multipack (~97% fill)
shuffle: true

# Trainable modules — 7 default projections (dense model)
targets:
  - down_proj
  - gate_proj
  - up_proj
  - q_proj
  - k_proj
  - v_proj
  - o_proj
offload_activations: true
attn_impl: auto
sample_every: 0             # judge by eval curve; before/after decode runs post-hoc

# Checkpoints (checkpoint_every, NOT save_every — save_every clobbers save_best)
checkpoint_every: 5         # matched to eval_every so every checkpoint has an eval
keep_checkpoints: 0         # keep all; suite prunes to top-4 held-out + final post-run

# Evaluation / run log
eval_split: test            # 116-row held-out split
eval_every: 5             # ~quarter-epoch (~22 packed steps/epoch at batch 4)
save_best: true
profile_dequant: 3
run_log: qlora_runs.csv
